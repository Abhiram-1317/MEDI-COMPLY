# ==============================================================================
# MEDI-COMPLY — Environment Variables
# Copy to `.env` and fill in your values.
# ==============================================================================

# Application
APP_NAME=MEDI-COMPLY
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://medi:medi@localhost:5432/medi_comply
REDIS_URL=redis://localhost:6379/0

# LLM
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_API_KEY=your-api-key-here
LLM_TIMEOUT_SECONDS=60

# Guardrails
GUARDRAIL_CONFIDENCE_THRESHOLD=0.85
GUARDRAIL_MAX_RETRIES=3
GUARDRAIL_ESCALATION_THRESHOLD=0.7

# Knowledge stores
KNOWLEDGE_VECTOR_DB_URL=http://localhost:8100
KNOWLEDGE_GRAPH_DB_URL=bolt://localhost:7687
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small

# Audit
AUDIT_RETENTION_DAYS=2555
AUDIT_LOG_LEVEL=INFO

# Security
SECURITY_ENABLE_PHI_DETECTION=true
SECURITY_ENABLE_PROMPT_INJECTION_DETECTION=true
